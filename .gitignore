# Data files must never be committed. This list is a safety net.
# The real rule is in the README: no data on GitHub, period.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
*.csv
*.tsv
*.xlsx
*.xls
*.sas7bdat
*.dta
*.sav
*.parquet
*.feather
*.rds
*.RData
*.rda
*.db
*.sqlite

# R session files
.Rhistory
.RData
.Rproj.user/
*.Rproj

# renv library folder, the lockfile IS committed
renv/library/
renv/local/
renv/cellar/
renv/staging/

# Python
__pycache__/
*.pyc
.venv/
venv/
.ipynb_checkpoints/

# OS clutter
.DS_Store
Thumbs.db

# credentials, just in case
.env
*.pem
*.key
